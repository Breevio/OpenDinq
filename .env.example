# Local API/Web ports used by `pnpm dev` and `pnpm start`.
OPENDINQ_API_PORT=3011
OPENDINQ_WEB_PORT=3012

# The web app calls the API through this URL.
NEXT_PUBLIC_OPENDINQ_API_URL=http://localhost:3011

# The MCP server calls the API through this URL.
OPENDINQ_API_URL=http://localhost:3011

# Optional: set to false in production-like environments to avoid demo profiles.
OPENDINQ_AUTO_SEED=true

# Optional: raises GitHub API limits for public profile imports.
GITHUB_TOKEN=

# Optional: enable LLM-backed profile generation with an OpenAI-compatible API.
OPEN_DINQ_ENABLE_LLM_GENERATION=false
OPEN_DINQ_LLM_PROVIDER=openai-compatible
OPEN_DINQ_LLM_MODEL=gpt-4.1-mini
OPEN_DINQ_LLM_API_KEY=
# OPEN_DINQ_LLM_BASE_URL=https://api.openai.com/v1
# OPEN_DINQ_LLM_CHAT_COMPLETIONS_URL=https://api.openai.com/v1/chat/completions
# OPEN_DINQ_LLM_TIMEOUT_MS=90000
# OPEN_DINQ_LLM_MAX_TOKENS=1200

# Optional: lets agent search call a web-search gateway that returns
# { "results": [{ "title": "...", "url": "...", "snippet": "..." }] }.
# OPEN_DINQ_WEB_SEARCH_URL=
# OPEN_DINQ_WEB_SEARCH_API_KEY=

# Example: NVIDIA NIM with GLM 5.1. Do not put real keys in this file.
# OPEN_DINQ_ENABLE_LLM_GENERATION=true
# OPEN_DINQ_LLM_PROVIDER=openai-compatible
# OPEN_DINQ_LLM_MODEL=z-ai/glm-5.1
# OPEN_DINQ_LLM_API_KEY=nvapi-...
# OPEN_DINQ_LLM_CHAT_COMPLETIONS_URL=https://integrate.api.nvidia.com/v1/chat/completions

# Optional: Postgres persistence. Leave unset for the default in-memory runtime.
# DATABASE_URL=postgresql://opendinq:opendinq@localhost:5432/opendinq

# Optional: override the agent tool-planning timeout (default: 15000 ms).
# OPEN_DINQ_AGENT_PLANNING_TIMEOUT_MS=15000

# Optional: override the connector search timeout (default: 15000 ms).
# OPEN_DINQ_CONNECTOR_SEARCH_TIMEOUT_MS=15000

# Security: CORS origin allowed for browser requests (default: http://localhost:3012).
# Use a specific origin in production. Set to "*" to allow any origin (not recommended).
OPEN_DINQ_CORS_ORIGIN=http://localhost:3012

# Security: rate limiting configuration.
# OPEN_DINQ_RATE_LIMIT_WINDOW_MS=60000
# OPEN_DINQ_RATE_LIMIT_MAX=100

# Security: maximum request body size in bytes (default: 1048576 = 1MB).
# OPEN_DINQ_MAX_BODY_SIZE=1048576

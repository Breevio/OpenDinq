generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id          String           @id @default(cuid())
  handle      String           @unique
  displayName String
  headline    String?
  bio         String?
  location    String?
  avatarUrl   String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  sources     IdentitySource[]
  artifacts   Artifact[]
  cards       Card[]
  skills      PersonSkill[]
}

model IdentitySource {
  id         String    @id @default(cuid())
  personId   String
  type       String
  url        String
  externalId String?
  rawJson    Json?
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  person     Person    @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([type, url])
  @@index([personId])
}

model Artifact {
  id          String   @id @default(cuid())
  personId    String
  sourceId    String?
  type        String
  title       String
  description String?
  url         String?
  metadata    Json?
  evidenceRaw Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  person      Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, type, url])
  @@index([personId])
}

model Card {
  id           String   @id @default(cuid())
  personId     String
  type         String
  title        String
  contentMd    String
  dataJson     Json?
  evidenceJson Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  person       Person   @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId])
}

model SkillTag {
  id     String        @id @default(cuid())
  name   String        @unique
  people PersonSkill[]
}

model PersonSkill {
  personId     String
  skillTagId   String
  score        Float
  evidenceJson Json
  person       Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  skillTag     SkillTag @relation(fields: [skillTagId], references: [id], onDelete: Cascade)

  @@id([personId, skillTagId])
}

model SearchQuery {
  id         String         @id @default(cuid())
  queryText  String
  parsedJson Json?
  createdAt  DateTime       @default(now())
  results    SearchResult[]
}

model SearchResult {
  id           String      @id @default(cuid())
  queryId      String
  personId     String
  score        Float
  explanation  String
  evidenceJson Json
  query        SearchQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  @@index([queryId])
  @@index([personId])
}

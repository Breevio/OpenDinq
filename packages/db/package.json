{
  "name": "@opendinq/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.build.json",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:validate": "DATABASE_URL=postgresql://opendinq:opendinq@localhost:5432/opendinq prisma validate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "NODE_OPTIONS=--conditions=development vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opendinq/core": "workspace:*",
    "@prisma/client": "^6.7.0",
    "@opendinq/shared": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^6.7.0"
  }
}
